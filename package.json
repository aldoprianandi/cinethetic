{
  "name": "cinethetic",
  "version": "0.1.0",
  "description": "Programmable social carousels — one JSON file, nine themes, rendered with Remotion, React, and TypeScript",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aldoprianandi/cinethetic.git"
  },
  "bugs": {
    "url": "https://github.com/aldoprianandi/cinethetic/issues"
  },
  "homepage": "https://github.com/aldoprianandi/cinethetic#readme",
  "keywords": [
    "carousel",
    "creative-coding",
    "design-system",
    "image-generation",
    "instagram",
    "programmatic-design",
    "react",
    "remotion",
    "social-media",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "studio": "remotion studio src/index.ts",
    "check:public": "node scripts/public-check.mjs",
    "check:data": "node scripts/check-data.mjs",
    "test:data": "node scripts/check-data.test.mjs",
    "compositions": "remotion compositions src/index.ts",
    "typecheck": "tsc --noEmit",
    "bundle": "remotion bundle src/index.ts",
    "render:slide": "remotion still src/index.ts DemoManifestSlide out/demo-slide.png",
    "render:preview": "remotion still src/index.ts DemoManifestPreview out/demo-preview.png",
    "render:demo": "node scripts/render-demo.mjs",
    "render:reel": "remotion render src/index.ts ThemeReel out/showcase/theme-reel.gif --codec=gif --scale=0.5",
    "render:hero": "remotion still src/index.ts HeroGrid out/showcase/hero.png --scale=0.5",
    "verify": "npm run check:public && npm run check:data && npm run test:data && npm run typecheck && npm run compositions && npm run render:demo && npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/sora": "^5.2.8",
    "@fontsource/archivo-black": "^5.2.8",
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/inter-tight": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.476"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.476",
    "@types/react": "19.2.17",
    "typescript": "5.9.3"
  }
}
